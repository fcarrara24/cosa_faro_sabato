# Database Configuration
# DATABASE_URL=postgresql://postgres:password@localhost:5432/bergamo_events

# For development with SQLite
DATABASE_URL=sqlite:///./bergamo_events.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Logging
LOG_LEVEL=INFO

# Geocoding (optional - you can use OpenStreetMap for free)
# NOMINATIM_USER_AGENT=bergamo-events-finder

# Scheduler Configuration
SCHEDULER_ENABLED=true

# CORS (for development)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
